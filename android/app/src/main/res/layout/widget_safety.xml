<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp">

    <!-- Left side: Status info -->
    <LinearLayout
        android:id="@+id/widget_status_area"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingEnd="12dp">

        <!-- App name -->
        <TextView
            android:id="@+id/widget_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tourist Safety"
            android:textColor="@color/widget_text_secondary"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08" />

        <!-- Status row: dot + text -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <ImageView
                android:id="@+id/widget_status_dot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/widget_status_dot_protected"
                android:contentDescription="Status indicator" />

            <TextView
                android:id="@+id/widget_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PROTECTED"
                android:textColor="@color/widget_success"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.06"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/widget_status_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You are safe"
            android:textColor="@color/widget_text_secondary"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Right side: SOS button -->
    <FrameLayout
        android:id="@+id/widget_sos_button"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/widget_sos_button"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="SOS"
            android:textColor="@color/widget_text_primary"
            android:textSize="16sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1" />

    </FrameLayout>

</LinearLayout>
