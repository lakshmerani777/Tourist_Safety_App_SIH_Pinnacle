.dart_tool/
**/build/
**/ephemeral/
**/doc/api/
.pub-cache/
.pub/
.flutter-plugins-dependencies
**/ios/Flutter/.last_build_id
*.symbols
*.map.json
coverage/

# === Android ===
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/android/.gradle/
**/android/local.properties
**/android/**/generated/

# === iOS / macOS ===
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Flutter.framework/
**/ios/Flutter/Flutter.podspec
**/macos/Flutter/ephemeral/

# === Python / Django backend ===
**/venv/
**/.venv/
**/env/
**/__pycache__/
**/*.pyc
**/*.pyo
**/.eggs/
**/*.egg-info/
**/*.egg
**/PinnacleBackend/**/migrations/
**/staticfiles/
**/static/
**/media/
*.sqlite3
*.db
.env
.env.*

# === Node (if any) ===
**/node_modules/

